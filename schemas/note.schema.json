{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hwdn.dev/schemas/note.schema.json",
  "title": "HWDN Note",
  "type": "object",
  "additionalProperties": true,
  "required": ["document", "pages"],
  "properties": {
    "document": {
      "$ref": "#/$defs/document"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/page"
      }
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/historyEntry"
      }
    }
  },
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "createdAt",
        "modifiedAt",
        "units",
        "defaultPageSize"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "modifiedAt": {
          "type": "string",
          "format": "date-time"
        },
        "units": {
          "type": "string",
          "enum": ["px", "pt", "mm"]
        },
        "defaultPageSize": {
          "$ref": "#/$defs/size"
        },
        "authors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/person"
          }
        },
        "sourceApplication": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "index", "size", "strokes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "size": {
          "$ref": "#/$defs/size"
        },
        "background": {
          "$ref": "#/$defs/background"
        },
        "strokes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stroke"
          }
        },
        "ocr": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ocrDetection"
          }
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "color": {
          "type": "string"
        },
        "style": {
          "type": "string",
          "enum": ["blank", "ruled", "grid", "dot-grid", "asset"]
        },
        "asset": {
          "type": "string"
        }
      }
    },
    "stroke": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "tool", "color", "width", "points"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "enum": ["pen", "pencil", "marker", "highlighter", "eraser"]
        },
        "color": {
          "type": "string"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blendMode": {
          "type": "string"
        },
        "smoothing": {
          "type": "string",
          "enum": ["none", "quadratic", "cubic", "catmull-rom"]
        },
        "interpolation": {
          "type": "string",
          "enum": ["linear", "bezier"]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/point"
          }
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": true,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "t": {
          "type": "number",
          "minimum": 0
        },
        "pressure": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tiltX": {
          "type": "number"
        },
        "tiltY": {
          "type": "number"
        },
        "azimuth": {
          "type": "number"
        },
        "altitude": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "ocrDetection": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "text", "bounds"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["block", "line", "word", "character"]
        },
        "text": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "bounds": {
          "$ref": "#/$defs/bounds"
        },
        "language": {
          "type": "string"
        },
        "strokeRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ocrDetection"
          }
        }
      }
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "historyEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version", "createdAt", "summary"],
      "properties": {
        "version": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "$ref": "#/$defs/person"
        },
        "summary": {
          "type": "string"
        },
        "changeSet": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
