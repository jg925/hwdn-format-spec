{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hwdn.dev/schemas/note.schema.json",
  "title": "HWDN Single-Canvas Note",
  "type": "object",
  "additionalProperties": true,
  "required": ["document", "canvas"],
  "properties": {
    "document": {
      "$ref": "#/$defs/document"
    },
    "canvas": {
      "$ref": "#/$defs/canvas"
    },
    "pages": false,
    "history": false
  },
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "createdAt",
        "modifiedAt",
        "units",
        "canvasSize"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "modifiedAt": {
          "type": "string",
          "format": "date-time"
        },
        "units": {
          "type": "string",
          "enum": ["px", "pt", "mm"]
        },
        "canvasSize": {
          "$ref": "#/$defs/size"
        },
        "authors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/person"
          }
        },
        "sourceApplication": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "size", "strokes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "$ref": "#/$defs/size"
        },
        "background": {
          "$ref": "#/$defs/background"
        },
        "strokes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stroke"
          }
        },
        "interpretation": {
          "$ref": "#/$defs/interpretation"
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
        },
        "style": {
          "type": "string",
          "enum": ["blank", "ruled", "grid", "dot-grid", "asset"]
        },
        "asset": {
          "type": "string"
        }
      }
    },
    "stroke": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "tool", "brush", "points"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "enum": ["pen", "pencil", "marker", "highlighter", "eraser"]
        },
        "brush": {
          "$ref": "#/$defs/brush"
        },
        "input": {
          "$ref": "#/$defs/input"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/point"
          }
        }
      }
    },
    "brush": {
      "type": "object",
      "additionalProperties": true,
      "required": ["color", "baseWidth"],
      "properties": {
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
        },
        "baseWidth": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "pressureCurve": {
          "type": "string",
          "enum": ["none", "linear"]
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string"
        },
        "device": {
          "type": "string"
        },
        "sampleRateHz": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": true,
      "required": ["x", "y", "t"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "t": {
          "type": "number",
          "minimum": 0
        },
        "pressure": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tiltX": {
          "type": "number"
        },
        "tiltY": {
          "type": "number"
        },
        "azimuth": {
          "type": "number"
        },
        "altitude": {
          "type": "number"
        }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["plainText"],
      "properties": {
        "plainText": {
          "type": "string"
        },
        "markdown": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "$ref": "#/$defs/interpretationSource"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        }
      }
    },
    "interpretationSource": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "human",
            "handwriting-recognition",
            "llm",
            "import",
            "app",
            "unknown"
          ]
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "contentBlock": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "document",
            "section",
            "heading",
            "paragraph",
            "line",
            "list",
            "listItem",
            "table",
            "tableRow",
            "tableCell",
            "checkbox",
            "equation",
            "code",
            "drawing",
            "word",
            "character",
            "unknown"
          ]
        },
        "role": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "markdown": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "checked": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "bounds": {
          "$ref": "#/$defs/bounds"
        },
        "strokeRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        }
      }
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
