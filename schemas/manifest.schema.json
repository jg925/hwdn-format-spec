{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hwdn.dev/schemas/manifest.schema.json",
  "title": "HWDN Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "format",
    "formatVersion",
    "fileName",
    "createdAt",
    "modifiedAt",
    "payload"
  ],
  "properties": {
    "format": {
      "const": "hwdn"
    },
    "formatVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "fileName": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "modifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "payload": {
      "type": "string",
      "const": "note.json"
    },
    "thumbnail": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "version": {
            "type": "string"
          }
        }
      }
    }
  }
}
